# Disable upload target for native_tool environment
Import("env")

from SCons.Script import AlwaysBuild, Command, Group, Import, SConsEnvironment, VariantDir, Alias

# Get the program node
progname = env.get("PROGNAME", "program.exe")
build_dir = env.get("BUILD_DIR", ".pio/build/native_tool")

# Find the upload alias and replace its actions
def disable_upload_action():
    from SCons.Node.Alias import Alias as SAlias
    # Get the 'upload' alias
    try:
        upload_node = env.subst_node("$UPLOADSOURCE")
    except:
        pass
    
    # Clear actions on the program executable that run it
    prog = env.Program(progname, [])
    
    # Remove the run action from upload
    env.Replace(__get_upload_tools=lambda env: [])

# Try to intercept by removing actions from the upload target  
def post_upload_fixup(source, target, env):
    # Do nothing - upload is disabled
    pass

# Replace the entire upload behavior
env.AddPostAction("upload", post_upload_fixup)