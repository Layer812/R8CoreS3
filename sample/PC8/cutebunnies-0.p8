			lx = (-cosphi*z - sinphi*z) + ppx
			ly = (sinphi*z - cosphi*z) + ppy
	
			rx = (cosphi*z - sinphi*z) + ppx
			ry = (-sinphi*z - cosphi*z) + ppy
	
