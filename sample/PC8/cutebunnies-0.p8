function hc(s)
  return 64-#s*2
end

precalc = 0
ff = 0

function efu_hei()
	rectfill(0,20,128,23,0)

	ff+=1
	if (ff > 1) then ff = 0 end

	local eh = 50
	local sc = 50
	local hori = 10
	local dist = 155.0

	local ppy=-t*30*40
	local ppx=-cos(t*5)*50

	local phi = 0.07+cos(t*0.75)*0.5
	
	local sinphi = sin(phi)
	local cosphi = cos(phi)

	local ii = 1
	local z = dist
	local zz = 2.0
	for ii = 1, 256 do

		z -= zz
		if (z < 20) then break end
		zz = z*0.02


		if(precalc==0) then
			lx = (-cosphi*z - sinphi*z) + ppx
			ly = (sinphi*z - cosphi*z) + ppy
	
			rx = (cosphi*z - sinphi*z) + ppx
			ry = (-sinphi*z - cosphi*z) + ppy
	
			dx = rotr(rx-lx,7)
		
			lxi[ii] = lx	
			rxi[ii] = rx	
			lyi[ii] = ly	
			ryi[ii] = ry	
		else
			lx = lxi[ii]+ppx
			rx = rxi[ii]+ppx
			ly = lyi[ii]+ppy
			ry = ryi[ii]+ppy
			dx = rotr(rx-lx,7)
		end
		
		
	
		ii += 1
				
		for i = 0, 127,2 do
			mt = mget(lx&63,ly&63)
			hs = (eh - mt) / z * sc + hori
			mt-=flr(z*0.06)
			
			if (mt<0) then mt = 0 end
			rectfill(i,hs,i+1,128-z*0.5,mt)
			lx += dx*2
		end

	end

	rectfill(0,128-17,128,128,0)

	if stat(24) < 5 then
		if stat(24) == 1 then
		xo = 28
		print("pumpuli",128-xo,112,2)
		end
		if stat(24) == 2 then
		xo = 16
		print("visy",128-xo,112,2)
		end
		if stat(24) == 3 then
		xo = 24
		print("zanagb",128-xo,112,2)
		end
	end

	poke4(0x5f10,0x8582.8000)
 poke4(0x5f14,0x8d05.8483)
 poke4(0x5f18,0x8f86.0d8c)
 poke4(0x5f1c,0x0787.0f06)
 poke(0x5f2e,1)

 yield()
end

