ch2={}
ch3={}
ch4={}
ti={0,0,0,0,0,0}
ppx = 0
ppy = 0
prep = 0
lxi = {}
rxi = {}
lyi = {}
ryi = {}


-- these will contain values
-- for their channels, and
-- can be used for more exact
-- syncing, for example:
-- hit[1]=(sefx[1]&0b0011)
-- and so whenever there's a
-- bd hit (fx 3) on track 1,
-- hit[1] will be 1
note={0,0,0,0}
inst={0,0,0,0}
sefx={0,0,0,0}
volu={0,0,0,0}
hit={0,0,0,0,0}
hitf={0,0,0,0,0}


-- which effect is played in ptr
efu={5,5,5,5,5,5,5,5,
     3,2,3,2,2,2,2,0,
     7,7,7,7,7,7,7,7,
     3,4,3,4,3,4,3,0,
     6,6,6,6,6,6,6,8,
     }
     
-- select by using efu[stat(24)]
-- and show scene based on that     
     
-- control values for effects
efv={0b00000000, -- efu 0
     0b00001011, -- efu 1
     0b11111111} -- efu 2? more?

pupuoli = 0
     
bg=0
scrstart=0x6000
scrend=0x7fff
t=0
tt=.0
dt=.0
ot=.0
xoff=0
yoff=0
cot=0
sit=0
of=0
f=0
