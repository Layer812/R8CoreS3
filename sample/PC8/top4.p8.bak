    𝘲(7, 1, 𝘬(d, 7, n, 1))
    if c == "race" and l % 15 == 0 then
      d𝘨 = dy()
    end
  elseif c == "start" then
    dv()
  end
  if c == "end" then
    d𝘵()
  end
  𝘮 = max(0, 𝘮 - 1)
  if k == "ice" then
    for d in all(𝘣) do
      d.d += d.dl
      d.e += sin(d.d / 128) / 3
      if d.d > 128 then
        d.d = 0
      end
    end
  end
  l = (l + 1) % 60
end

function db()
  p = 5
end

function _draw()
  if c == "race" or c == "end" then
    local d, n = 0, 0
    if p > 0 then
      d, n = rnd(p) - p / 2, rnd(p) - p / 2
      p *= .95
      if p < 1 then
        p = 0
      end
    end
    camera(a.e - 64 + d, a.d - 64 + n)
    local n, d = flr(a.e / 8) - 8, flr(a.d / 8) - 8
    n, d = mid(0, n, 96), mid(0, d, 96)
    pal()
    if k == "ice" then
      pal(7, 6)
      pal(1, 6)
      pal(3, 7)
      pal(9, 13)
      pal(11, 13)
      pal(8, 13)
      pal(10, 7)
      pal(2, 5)
      pal(4, 5)
      cls(5)
    else
      cls(3)
    end
    palt(0, false)
    map(n, d, n * 8, d * 8, 17, 17)
    pal()
    if k == "ice" then
      pal(0, 13)
      pal(1, 6)
    end
    𝘳()
    for d = d - 1, d + 17 do
      for n = n, n + 17 do
        local e = mget(n, d)
        if fget(e, 2) then
          if not fget(mget(n, d + 1), 2) then
            spr(73, n * 8, d * 8 + 8)
          end
          if not fget(mget(n, d - 1), 2) then
            spr(74, n * 8, d * 8 - 8)
          end
          if not fget(mget(n - 1, d), 2) then
            spr(86, n * 8 - 8, d * 8)
          end
          if not fget(mget(n + 1, d), 2) then
            spr(87, n * 8 + 8, d * 8)
          end
        end
        if l >= 0 and l < 15 then
          if e == 19 then
            spr(23, n * 8, d * 8)
          end
        elseif l >= 15 and l < 30 then
          if e == 18 then
            spr(22, n * 8, d * 8)
          end
        elseif l >= 30 and l < 45 then
          if e == 17 then
            spr(21, n * 8, d * 8)
          end
        elseif l >= 45 and l < 60 then
          if e == 16 then
            spr(20, n * 8, d * 8)
          end
        end
      end
    end
    for d in all(w) do
      d:k()
    end
    if d1 then
      d𝘱()
    end
    for d in all(i) do
      spr(1, d.e - 4, d.d - 4 + 1)
    end
    dw()
    dc(i)
    for d in all(i) do
      d𝘸(d)
    end
    camera(0, 0)
    if k == "ice" then
      for d in all(𝘣) do
        pset(d.e, d.d, 7)
      end
    end
    if c == "race" then
      f("⁶w⁶t" .. 𝘩(a.h), 48, 112, 7)
      f(𝘺(time), 110, 3, 7)
    end
    if 𝘯 > 0 then
      f("⁶w⁶tlap " .. a.r .. "/" .. q, 34, 74, 10)
      if a.r > 1 then
        for d in all(i) do
          if d.h == 1 then
            local d = d
            local d = d.c.t
            local n = d == "red" and "you're" or d
            local e, d = n .. " in the lead", 𝘭[d]
            if d == 0 or d == 8 then
              d = 7
            end
            local e = 64 - #e * 2
            f(n, e, 87, d)
            f("in the lead", e + #n * 4 + 6, 87, 7)
            break
          end
        end
      end
    end
    𝘯 = max(0, 𝘯 - 1)
    di()
    rect(5, 108, 18, 124, 0)
    rect(4, 109, 19, 123, 0)
    rect(5, 109, 18, 122, 13)
    line(5, 109, 9, 109, 6)
    line(5, 113, 5, 109, 6)
    rect(6, 110, 17, 121, 5)
    rectfill(7, 111, 16, 120, 1)
    local d = a.p
    if d == "missile" then
      spr(7, 8, 112)
    elseif d == "bomb" then
      spr(14, 8, 112)
    elseif d == "boost" then
      spr(41, 8, 112)
    end
    if a.r == 0 then
      rectfill(32, 75, 96, 103, 0)
      rectfill(33, 76, 95, 102, 6)
      rectfill(34, 77, 94, 101, 5)
      rectfill(35, 78, 93, 100, 1)
      f("steer ⬅️ ➡️", 43, 79, 7)
      f("accelerate ❎", 40, 87, 7)
      f("use item 🅾️", 45, 95, 7)
    end
    if 𝘮 > 0 then
      f(𝘸, 64 - #𝘸 * 4 / 2 + cos(l / 30) * 2, 10 + sin(l / 30) * 2, 𝘶)
    end
  elseif c == "start" then
    dg()
  end
  if c == "end" then
    d𝘴()
  end
end


