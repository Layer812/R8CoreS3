function d_(n, c, e, a, d)
  local o, f, d, l = d.𝘣, d.𝘨, d.𝘬, d.𝘲
  local d, n, c, l = n - e, c - a, d - o, l - f
  if d == 0 and n == 0 then
    return false
  end
  local o, a, e = e - o, a - f, d * l - n * c
  if e == 0 then
    return false
  end
  local d, n = (c * a - l * o) / e, (d * a - n * o) / e
  return d >= 0 and d <= 1 and n >= 0 and n <= 1
end

function dm(e, a, d)
  local d, n, o, f = d.𝘣, d.𝘨, d.𝘬, d.𝘲
  local c = (o - d) * (o - d) + (f - n) * (f - n)
  if c == 0 then
    local d, n = e - d, a - n
    return sqrt(d * d + n * n) * 8
  end
  local c = ((e - d) * (o - d) + (a - n) * (f - n)) / c
  if c < 0 then
    local d, n = e - d, a - n
    return sqrt(d * d + n * n) * 8
  elseif c > 1 then
    local d, n = e - o, a - f
    return sqrt(d * d + n * n) * 8
  else
    local d, n = d + c * (o - d), n + c * (f - n)
    local d, n = e - d, a - n
    return sqrt(d * d + n * n) * 8
  end
end

function 𝘤(d, n, e, a)
  local d, n = (d - e) / 64, (n - a) / 64
  local d = d * d + n * n
  if d < 0 then
    return 32767.99999
  end
  return sqrt(d) * 64
end

