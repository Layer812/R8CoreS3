[SEARCH]
function draw_enemies (layer)
 for e in all(enemies) do
  if e.layer == layer then
   local o = obstacletable[e.obstacle]
   pal(3,clr.b)
   spr(o.sprite, e.x, e.y)
   pal(3,3)
  end
 end
end
[REPLACE]
function draw_enemies (layer)
