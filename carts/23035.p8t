[SEARCH]
function update_clouds ()
 for c in all(clouds) do
  c.x -= c.speed

  if c.x < -32 then
   --wrap around
   c.x = 128

   -- randomize sprite
   c.sprite = pick_random_cloud_sprite(c.big)

   -- randomize y value
   c.y = pick_random_cloud_y()
  end
 end
end
[REPLACE]
function update_clouds ()
 for i=1,count(clouds) do
  local c=clouds[i]
  c.x -= c.speed

  if c.x < -32 then
   --wrap around
   c.x = 128

   -- randomize sprite
   c.sprite = pick_random_cloud_sprite(c.big)

   -- randomize y value
   c.y = pick_random_cloud_y()
  end
 end
end
