[SEARCH]
function corners_intersecting_box (corners,x1,y1,x2,y2)
 for c in all(corners) do
  -- loop through corners of bounds,
  -- check if they're in the box
  if c[1] >= min(x1,x2) and
     c[1] <= max(x1,x2) and
     c[2] >= min(y1,y2) and
     c[2] <= max(y1,y2) then
   return true
  end
 end
 return false
end
[REPLACE]
function corners_intersecting_box (corners,x1,y1,x2,y2)
 for i=1,count(corners) do
  local c=corners[i]
  -- loop through corners of bounds,
  -- check if they're in the box
  if c[1] >= min(x1,x2) and
     c[1] <= max(x1,x2) and
     c[2] >= min(y1,y2) and
     c[2] <= max(y1,y2) then
   return true
  end
 end
 return false
end
