-- particles
particles={}
confetti={}
function add_particle(x,y,dx,dy,tbl)
 local p={}
 p.c={4,9}
 p.t=15
 p.x=x
 p.y=y
 p.dx=dx
 p.dy=dy
 p.ix=1
 p.iy=1
 p.f=116
 p.tf=4
 p.fc=0
 p.a=tbl
 add(tbl,p)
 return p
end

function update_particle(p)
 p.x+=p.dx
 p.y+=p.dy
 p.dx*=p.ix
 p.dy*=p.iy
 p.t-=1
 if (p.t%2==0) p.fc+=1
 if (p.fc==p.tf) p.fc=0
 
 if (p.t<0) del(p.a,p)
end

function draw_particle(p,l)
 local r=5*(1-(p.t/15))-l+1
 circfill(p.x,p.y-l,r,p.c[l])
end

function draw_confetti(p)
 pal(8,p.c[1])
 pal(14,p.c[2])
 
 spr(p.f+p.fc,p.x,p.y)
 pal()
end
[REPLACE]
-->8
-- particles
MAX_PARTS=64
part_x={} part_y={} part_dx={} part_dy={} part_ix={} part_iy={}
part_t={} part_f={} part_tf={} part_fc={} part_c1={} part_c2={} part_tbl={}
for i=1,MAX_PARTS do part_t[i]=-1 end

function init_particles()
 for i=1,MAX_PARTS do part_t[i]=-1 end
end

function add_particle(x,y,dx,dy,tbl)
 for i=1,MAX_PARTS do
  if part_t[i]<0 then
   part_c1[i]=4 part_c2[i]=9
   part_t[i]=15
   part_x[i]=x part_y[i]=y
   part_dx[i]=dx part_dy[i]=dy
   part_ix[i]=1 part_iy[i]=1
   part_f[i]=116 part_tf[i]=4 part_fc[i]=0
   part_tbl[i]=tbl
   return i
  end
 end
 return 0
end

function update_particles()
 for i=1,MAX_PARTS do
  if part_t[i]>=0 then
   part_x[i]+=part_dx[i]
   part_y[i]+=part_dy[i]
   part_dx[i]*=part_ix[i]
   part_dy[i]*=part_iy[i]
   part_t[i]-=1
   if (part_t[i]%2==0) part_fc[i]+=1
   if (part_fc[i]==part_tf[i]) part_fc[i]=0
  end
 end
end

function draw_particles()
 for i=1,MAX_PARTS do
  if part_t[i]>=0 and part_tbl[i]==1 then
   local r=5*(1-(part_t[i]/15))
   circfill(part_x[i],part_y[i]-1,r,part_c1[i])
  end
 end
 for i=1,MAX_PARTS do
  if part_t[i]>=0 and part_tbl[i]==1 then
   local r=5*(1-(part_t[i]/15))-1
   circfill(part_x[i],part_y[i]-2,r,part_c2[i])
  end
 end
 for i=1,MAX_PARTS do
  if part_t[i]>=0 and part_tbl[i]==2 then
   pal(8,part_c1[i])
   pal(14,part_c2[i])
   spr(part_f[i]+part_fc[i],part_x[i],part_y[i])
   pal()
  end
 end
end
