function draw_segment(n,i)
 bgcols={9,15}
 if (i>120 and i<260) then bgcols={2,4} end
 if (i>260 and i<290) then bgcols={1,5} end

 sidecols={7,6,7,2,1,2}
 if (i>260 and i<290) then sidecols={1,5,1,13,1,13} end

 rectfill(0,
          seg_p1_scrn_y[n],
          127,
          seg_p2_scrn_y[n]+1,
           bgcols[1+i%2])
 
 -- road
 polygon(seg_p1_scrn_x[n]-seg_p1_scrn_w[n],
         seg_p1_scrn_y[n],
         seg_p1_scrn_w[n]*2,
         seg_p2_scrn_x[n]-seg_p2_scrn_w[n],
         seg_p2_scrn_y[n]+1,
         seg_p2_scrn_w[n]*2,
         seg_c[i])
         
 -- sides and lanes
 local w1=seg_p1_scrn_w[n]/20
 local w2=seg_p2_scrn_w[n]/20
 if (i%2==0) then
  polygon(seg_p1_scrn_x[n]+w1,
          seg_p1_scrn_y[n],
           w2,
          seg_p2_scrn_x[n]+w2,
          seg_p2_scrn_y[n]+1,
          w2,
          7)
 end
 polygon(seg_p1_scrn_x[n]-seg_p1_scrn_w[n],
         seg_p1_scrn_y[n],
         -w1,
         seg_p2_scrn_x[n]-seg_p2_scrn_w[n],
         seg_p2_scrn_y[n]+1,
         -w2,
         sidecols[1+i%2])
 polygon(seg_p1_scrn_x[n]+seg_p1_scrn_w[n],
         seg_p1_scrn_y[n],
         -w1,
         seg_p2_scrn_x[n]+seg_p2_scrn_w[n],
         seg_p2_scrn_y[n]+1,
         -w2,
         sidecols[1+i%2]) 
end
