[SEARCH]
draw_hair=function(obj,facing)
	local last={x=obj.x+4-facing*2,y=obj.y+(btn(k_down) and 4 or 3)}
	foreach(obj.hair,function(h)
		h.x+=(last.x-h.x)/1.5
		h.y+=(last.y+0.5-h.y)/1.5
		circfill(h.x,h.y,h.size,8)
		last=h
	end)
end
[REPLACE]
local dh_last_x=0
local dh_last_y=0
local function dh_upd(h)
	h.x+=(dh_last_x-h.x)/1.5
	h.y+=(dh_last_y+0.5-h.y)/1.5
	circfill(h.x,h.y,h.size,8)
	dh_last_x=h.x
	dh_last_y=h.y
end
draw_hair=function(obj,facing)
	dh_last_x=obj.x+4-facing*2
	dh_last_y=obj.y+(btn(k_down) and 4 or 3)
	foreach(obj.hair,dh_upd)
end
